# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────

PORT=4300

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────

# Path on the Pi — /srv/storage/ is the external HDD, never touched by deploys
DB_PATH=/srv/storage/TelAviv2030/telaviv.db

# ─────────────────────────────────────────────
# OAuth — Google
# ─────────────────────────────────────────────

# Create an OAuth app at: https://console.cloud.google.com
#   → APIs & Services → Credentials → Create Credentials → OAuth client ID
#   → Application type: Web application
#   → Add authorised redirect URI: https://telaviv.yumehana.dev/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://telaviv.yumehana.dev/api/auth/google/callback

# ─────────────────────────────────────────────
# OAuth — Discord
# ─────────────────────────────────────────────

# Create an OAuth app at: https://discord.com/developers/applications
#   → New Application → OAuth2 → Add Redirect: https://telaviv.yumehana.dev/api/auth/discord/callback
#   → Required scopes: identify, guilds.members.read
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=https://telaviv.yumehana.dev/api/auth/discord/callback

# Your TelAviv Discord server ID
#   → In Discord: right-click the server icon → Copy Server ID (enable Developer Mode first)
DISCORD_GUILD_ID=

# The role ID that means "TelAviv member" — holders get instant approval on login
#   → In Discord: right-click the role in Server Settings → Roles → Copy Role ID
DISCORD_MEMBER_ROLE_ID=

# ─────────────────────────────────────────────
# Notifications — Discord Webhook
# ─────────────────────────────────────────────

# Webhook URL for posting notifications (new contributions, approvals, etc.)
#   → In Discord: channel settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=

# ─────────────────────────────────────────────
# Payment — TWINT
# ─────────────────────────────────────────────

# URL to the TWINT QR code image shown on the contribute page
# Can be a hosted image URL or a base64 data URI
TWINT_QR_CODE_URL=

# ─────────────────────────────────────────────
# Payment — Stripe (Phase 2, leave blank for now)
# ─────────────────────────────────────────────

# Create at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Webhook secret from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# Discord Bot (Phase 2, leave blank for now)
# ─────────────────────────────────────────────

# Bot token from: https://discord.com/developers/applications → Bot → Reset Token
DISCORD_BOT_TOKEN=